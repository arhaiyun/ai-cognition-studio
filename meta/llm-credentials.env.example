# LLM 统一凭证 · 环境变量模板
# 用法：cp meta/llm-credentials.env.example .private/llm-credentials.env
# 然后填入真实 Key（.private/ 不入库 — 公开仓库更须遵守）

# 默认使用的 profile（与 meta/llm-providers.yaml 中 id 对应）
LLM_DEFAULT_PROFILE=deepseek-media-agent

# ── DeepSeek · media-agent ─────────────────────────────
DEEPSEEK_MEDIA_AGENT_API_KEY=
DEEPSEEK_MEDIA_AGENT_BASE_URL=https://api.deepseek.com
DEEPSEEK_MEDIA_AGENT_MODEL=deepseek-v4-flash

